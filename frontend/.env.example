# Use /api/v1 with the Vite proxy during local development.
# For separate production hosts, set the full API URL, for example:
# VITE_API_URL=https://api.example.com/api/v1
VITE_API_URL=/api/v1

# true bypasses the route guard with a local demo identity for UI-only development.
# API-backed screens still require the backend. Keep false in production.
VITE_DEMO_MODE=false
